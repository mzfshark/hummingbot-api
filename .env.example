# Axodus Trading Suit - templates sem segredos
# Copie apenas as seções relevantes para os arquivos:
#   .env.postgres
#   .env.mqtt
#   .env.hummingbot
#   .env.mcp
#   .env.condor
#   .env.trinity

# ---------------------------------------------------------------------------
# .env.postgres
# ---------------------------------------------------------------------------
POSTGRES_DB=hummingbot_api
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_INITDB_ARGS=--encoding=UTF8

# ---------------------------------------------------------------------------
# .env.mqtt
# ---------------------------------------------------------------------------
EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=change_me_emqx_dashboard_password
EMQX_DASHBOARD__DEFAULT_USERNAME=admin
EMQX_DASHBOARD__DEFAULT_PASSWORD=change_me_emqx_dashboard_password
MQTT_HUMMINGBOT_USERNAME=hummingbot_api
MQTT_HUMMINGBOT_PASSWORD=change_me_hummingbot_mqtt_password
MQTT_MCP_USERNAME=mcp_user
MQTT_MCP_PASSWORD=change_me_mcp_mqtt_password
MQTT_CONDOR_USERNAME=condor_user
MQTT_CONDOR_PASSWORD=change_me_condor_mqtt_password
MQTT_DATA_COLLECTOR_USERNAME=data_collector
MQTT_DATA_COLLECTOR_PASSWORD=change_me_data_collector_mqtt_password
MQTT_TRINITY_USERNAME=trinity_user
MQTT_TRINITY_PASSWORD=change_me_trinity_mqtt_password

# ---------------------------------------------------------------------------
# .env.hummingbot
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://admin:change_me_postgres_password@postgres:5432/hummingbot_api
BROKER_HOST=emqx
BROKER_PORT=1883
BROKER_USERNAME=hummingbot_api
BROKER_PASSWORD=change_me_hummingbot_mqtt_password
GATEWAY_URL=http://host.docker.internal:15888
USERNAME=admin
PASSWORD=change_me_api_password
HBOT_IMAGE=hummingbot/hummingbot:development
TRADINGBOT_PATH=/opt/tradingbot
DEBUG_MODE=false
CONFIG_PASSWORD=change_me_config_password
ACCOUNT_UPDATE_INTERVAL=5
BANNED_TOKENS=["NAV","ARS","ETHW","ETHF"]
AWS_API_KEY=
AWS_SECRET_KEY=
AWS_S3_DEFAULT_BUCKET_NAME=
LOGFIRE_ENVIRONMENT=dev

# ---------------------------------------------------------------------------
# .env.mcp
# ---------------------------------------------------------------------------
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=3000
MCP_ALLOWED_ORIGINS=http://localhost:3000
HUMMINGBOT_API_URL=http://hummingbot-api:8000
HUMMINGBOT_USERNAME=admin
HUMMINGBOT_PASSWORD=change_me_api_password
HBOT_IMAGE=hummingbot/hummingbot:development
HUMMINGBOT_TIMEOUT=30
HUMMINGBOT_MAX_RETRIES=3
HUMMINGBOT_RETRY_DELAY=2
HUMMINGBOT_LOG_LEVEL=INFO
MCP_REQUIRE_SESSION=1
MCP_SESSION_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# .env.condor
# ---------------------------------------------------------------------------
TELEGRAM_TOKEN=
ADMIN_USER_ID=
CONDOR_TOKEN=
WEB_URL=http://localhost:8088
OPENAI_API_KEY=
HBOT_IMAGE=hummingbot/hummingbot:development

# ---------------------------------------------------------------------------
# .env.trinity
# ---------------------------------------------------------------------------
HUMMINGBOT_API_URL=http://localhost:8000
HUMMINGBOT_USERNAME=admin
HUMMINGBOT_PASSWORD=change_me_api_password
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=trinity_user
MQTT_PASSWORD=change_me_trinity_mqtt_password
MCP_URL=http://localhost:3000/mcp

# Configuração do MCP Server
# Este arquivo deve ser usado como env_file no serviço mcp-server do docker-compose

# URL da Hummingbot API
HUMMINGBOT_API_URL=http://hummingbot-api:8000

# Credenciais da API (usadas para autenticação básica)
HUMMINGBOT_API_USERNAME=admin
HUMMINGBOT_API_PASSWORD=admin

# MQTT Broker (EMQX) - para comunicação em tempo real
BROKER_HOST=emqx
BROKER_PORT=1883
BROKER_USER=hummingbot
BROKER_PASSWORD=hummingbot_pass

# Gateway URL (Hummingbot Gateway)
GATEWAY_URL=http://host.docker.internal:15888

# Banco de Dados (opcional, se o MCP precisar acessar diretamente)
DATABASE_URL=postgresql+asyncpg://hbot:hummingbot-api@postgres:5432/hummingbot_api
